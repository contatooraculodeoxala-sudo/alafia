{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [
      {
        "source": "/api/:path*",
        "destination": "http://localhost:3001/api/:path*",
        "regex": "^/api(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      },
      {
        "source": "/auth/:path*",
        "destination": "http://localhost:3001/auth/:path*",
        "regex": "^/auth(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      },
      {
        "source": "/publico/:path*",
        "destination": "http://localhost:3001/publico/:path*",
        "regex": "^/publico(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      }
    ],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/cadastro",
      "regex": "^/cadastro(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/cadastro(?:/)?$"
    },
    {
      "page": "/clientes",
      "regex": "^/clientes(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/clientes(?:/)?$"
    },
    {
      "page": "/configuracoes",
      "regex": "^/configuracoes(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/configuracoes(?:/)?$"
    },
    {
      "page": "/consultas",
      "regex": "^/consultas(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/consultas(?:/)?$"
    },
    {
      "page": "/equipe",
      "regex": "^/equipe(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/equipe(?:/)?$"
    },
    {
      "page": "/estoque",
      "regex": "^/estoque(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/estoque(?:/)?$"
    },
    {
      "page": "/financeiro",
      "regex": "^/financeiro(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/financeiro(?:/)?$"
    },
    {
      "page": "/marketing",
      "regex": "^/marketing(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/marketing(?:/)?$"
    },
    {
      "page": "/relatorios",
      "regex": "^/relatorios(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/relatorios(?:/)?$"
    },
    {
      "page": "/trabalhos",
      "regex": "^/trabalhos(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/trabalhos(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}